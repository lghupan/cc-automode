# Container C — YOLO mode (--dangerously-skip-permissions, no hooks, no CLAUDE.md)
# Baseline: Claude with full bypass and zero safety layer.

FROM node:20-slim

RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN if [ -d /opt/claude-code-src ]; then \
      cd /opt/claude-code-src && \
      npm install --omit=optional 2>/dev/null || true && \
      ln -sf /opt/claude-code-src/cli.js /usr/local/bin/claude && \
      chmod +x /usr/local/bin/claude; \
    else \
      npm install -g @anthropic-ai/claude-code; \
    fi

# Benchmark files
COPY benchmark/ /benchmark/

# Workspace init script
COPY docker/workspace/init.sh /init.sh
RUN chmod +x /init.sh

RUN mkdir -p /workspace/.claude /workspaces /results && \
    echo '{"permissions":{"defaultMode":"acceptEdits"}}' > /workspace/.claude/settings.json && \
    chown -R node:node /workspace /workspaces /results /benchmark

# No CLAUDE.md — zero LLM-level security directives

USER node
WORKDIR /workspace

ENV CONTAINER_NAME=yolo
ENV CLAUDE_EXTRA_FLAGS=--dangerously-skip-permissions
ENV HOME=/home/node

CMD ["python3", "/benchmark/runner.py"]
